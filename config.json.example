{
  "admin_password": "change-me-use-env-or-admin-panel",
  "server": {
    "host": "0.0.0.0",
    "port": 8080
  },
  "rate_limit": {
    "global_rpm": 10000,
    "default_key_rpm": 60
  },
  "models": {
    "default": {
      "source_base_url": "https://openrouter.ai/api/v1",
      "source_model": "qwen/qwen3.6-plus:free",
      "source_api_key": "change-me-set-via-env-or-admin-panel",
      "enabled": true
    }
  },
  "logging": {
    "level": "INFO",
    "file": "logs/relay.log",
    "max_size_mb": 100,
    "retention_days": 30
  }
}