# API Relay Service - Environment Variables
# Copy this file to .env and fill in your actual values

# Admin password for the management panel (REQUIRED)
ADMIN_PASSWORD=your-secure-admin-password

# Default source API configuration (if no database entries exist)
SOURCE_API_URL=https://openrouter.ai/api/v1
SOURCE_API_KEY=your-source-api-key-here
SOURCE_MODEL=qwen/qwen3.6-plus:free

# Server settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
